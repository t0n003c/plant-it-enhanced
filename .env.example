# Docker Compose deployment. Relative paths are resolved from the directory
# containing the Compose file. Use absolute /volume1 paths with the NAS example.
PLANTIT_IMAGE=ghcr.io/t0n003c/plant-it-enhanced:latest
PLANTIT_API_HOST_PORT=8080
PLANTIT_WEB_HOST_PORT=3000
PLANTIT_UPLOAD_PATH=./data/upload
PLANTIT_DB_PATH=./data/mysql
# Used only by compose.nas.example.yaml. The network must already exist.
PLANTIT_PROXY_NETWORK=TinhnasNetwork

# Database initialization. Changing these values does not update an existing
# MySQL data directory; keep them synchronized with the application settings.
MYSQL_DATABASE=bootdb
MYSQL_USER=plantit
MYSQL_PASSWORD=replace-with-a-long-database-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-root-password

# Authentication
JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_EXP=1

# Application
TZ=UTC
# Optional label shown in diagnostics. Set this to the NAS public egress IP if
# a provider account uses an IP allowlist.
PUBLIC_OUTBOUND_IP=

# Optional: enables camera-based identification (free key from my.plantnet.org).
# Keep "Expose my API key" disabled for server-side use. If you enable IP
# restrictions instead, authorize the NAS's public outbound IP.
PLANTNET_URL=https://my-api.plantnet.org
PLANTNET_API_KEY=
PLANTNET_MAX_RESULTS=5
PLANTNET_MIN_CONFIDENCE=0.05
# Allows a guided identification request with several compressed photos.
MAX_UPLOAD_REQUEST_SIZE=50MB

# Optional: first source for structured care data. Some species have sparse records.
TREFLE_URL=https://trefle.io
TREFLE_TOKEN=

# Optional final care fallback. Perenual's free plan exposes details only for a
# limited species-ID range, so many familiar plants require a paid plan. The
# bundled Extension-sourced catalog works without this key.
PERENUAL_URL=https://www.perenual.com/api
PERENUAL_API_KEY=
USERS_LIMIT=-1
UPLOAD_DIR=/upload-dir
API_PORT=8080
LOG_LEVEL=INFO
INTERNAL_LOG_LEVEL=ERROR
JPA_LOG=false
SPRING_LOG_REQUEST=false
ALLOWED_ORIGINS=*
APP_GITHUB_REPOSITORY=t0n003c/plant-it-enhanced
CONTACT_MAIL=
MAX_REQUESTS_PER_MINUTE=999
REMINDER_NOTIFY_CHECK=0 30 7 * * *

# Optional FloraCodex fallback
FLORACODEX_KEY=
FLORACODEX_URL=https://api.floracodex.com

# Common-name discovery and taxonomy verification
INATURALIST_ENABLED=true
INATURALIST_URL=https://api.inaturalist.org
INATURALIST_PLACE_ID=1
INATURALIST_REQUESTS_PER_SECOND=1
INATURALIST_REQUEST_BURST=2
PLANT_SEARCH_LOCALE=en
PLANT_SEARCH_REGION=US
PLANT_SEARCH_USER_AGENT=Plant-it-enhanced-self-hosted
GBIF_URL=https://api.gbif.org
GBIF_MIN_CONFIDENCE=90

# Redis
CACHE_TYPE=redis
CACHE_TTL=86400
CACHE_USERNAME=default
CACHE_PASSWORD=

# Image limits
MAX_ORIGIN_IMG_SIZE=10000000
MAX_UPLOAD_IMG_SIZE=15MB

# Optional notification dispatchers
NTFY_ENABLED=false
GOTIFY_ENABLED=false

# Optional email delivery for password resets and notifications
SMTP_HOST=
SMTP_PORT=
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_START_TTL=true
