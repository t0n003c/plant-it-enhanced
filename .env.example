# Database initialization. Changing these values does not update an existing
# MySQL data directory; keep them synchronized with the application settings.
MYSQL_DATABASE=bootdb
MYSQL_USER=plantit
MYSQL_PASSWORD=replace-with-a-long-database-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-root-password

# Authentication
JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_EXP=1

# Application
TZ=UTC

# Optional: enables camera-based identification (free key from my.plantnet.org).
PLANTNET_URL=https://my-api.plantnet.org
PLANTNET_API_KEY=
PLANTNET_MAX_RESULTS=5
PLANTNET_MIN_CONFIDENCE=0.05

# Optional: enriches saved species with attributable light and soil-moisture data.
TREFLE_URL=https://trefle.io
TREFLE_TOKEN=
USERS_LIMIT=-1
UPLOAD_DIR=/upload-dir
API_PORT=8080
LOG_LEVEL=INFO
ALLOWED_ORIGINS=*
APP_GITHUB_REPOSITORY=t0n003c/plant-it-enhanced

# Optional FloraCodex fallback
FLORACODEX_KEY=
FLORACODEX_URL=https://api.floracodex.com

# Common-name discovery and taxonomy verification
INATURALIST_ENABLED=true
INATURALIST_PLACE_ID=1
INATURALIST_REQUESTS_PER_SECOND=1
INATURALIST_REQUEST_BURST=2
PLANT_SEARCH_LOCALE=en
PLANT_SEARCH_REGION=US
PLANT_SEARCH_USER_AGENT=Plant-it-enhanced-self-hosted
GBIF_MIN_CONFIDENCE=90

# Redis
CACHE_TTL=86400
